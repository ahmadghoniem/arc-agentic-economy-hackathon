CIRCLE_API_KEY=
# Circle W3S entity secret, only if SDK/client.pay requires it:
ENTITY_SECRET=
# Existing Circle wallet ID to pay from, if using Circle W3S wallet flow:
CIRCLE_WALLET_ID=
# Optional wallet set ID if wallet creation is used:
CIRCLE_WALLET_SET_ID=
# Arc Testnet settings:
OMNICLAW_NETWORK=ARC_TESTNET
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_EXPLORER_URL=https://testnet.arcscan.app
# Optional only if exact x402 / Gateway signing flow requires it:
OMNICLAW_PRIVATE_KEY=
# Optional: local seller host used for "/ping" and "/data" endpoint shortcuts
SELLER_BASE_URL=http://localhost:8000
# Optional: force an onchain proof transfer when endpoint payments fall back to custodial mode.
# Use for judge/demo proof; this can increase tx count.
OMNICLAW_FORCE_ONCHAIN_PROOF=false
# Required when proof mode is true: recipient address for proof transfers.
OMNICLAW_PROOF_RECIPIENT=
